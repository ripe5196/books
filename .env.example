CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Frontend-safe
# Folder values must match Cloudinary asset_folder or public_id prefix (e.g. lives/ or us/).
# If assets are not tagged, the gallery falls back to folder-only, then tag-only requests.
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_FOLDER_US=us
VITE_CLOUDINARY_FOLDER_YES=the yes
VITE_CLOUDINARY_FOLDER_FOREVER=forever
VITE_CLOUDINARY_FOLDER_THROWBACK=throwback
VITE_CLOUDINARY_TAG_US=lives
VITE_CLOUDINARY_TAG_YES=engagement
VITE_CLOUDINARY_TAG_FOREVER=wedding
VITE_CLOUDINARY_TAG_THROWBACK=school

# If folder+tag returns nothing but the folder has media, return unfiltered folder results (dev API only).
# CLOUDINARY_ALLOW_TAG_FALLBACK=true

# Optional for persistent Timeline data (Redis REST API)
REDIS_URL=your_redis_host_or_url
REDIS_TOKEN=your_redis_token

# Optional: protect Timeline write APIs (POST/PUT/DELETE)
TIMELINE_WRITE_TOKEN=your_private_write_token

# Site-level access password for full admin mode
SITE_ACCESS_PASSWORD=your_site_access_password
